# ============================================
# Minthive 环境变量模板
# ============================================
# 复制此文件为 .env 并填写实际值：
#   cp .env.example .env
# ============================================

# ---------- MySQL 数据库 ----------
MYSQL_DEV_PASSWORD=your_mysql_password

# ---------- Redis ----------
REDIS_DEV_PASSWORD=your_redis_password  # 无密码留空即可

# ---------- MinIO 对象存储 ----------
MINIO_DEV_ACCESS_KEY=your_minio_access_key
MINIO_DEV_SECRET_KEY=your_minio_secret_key

# ---------- JWT 签名密钥 ----------
# 生产环境请更换为强随机字符串（至少 256 位），可用 openssl rand -base64 32 生成
JWT_DEV_SECRET=your_jwt_secret_key_here

# ---------- AI 服务 (Cloud 模式) ----------
# 使用 local 模式时此项可忽略
AI_CLOUD_DEV_API_KEY=sk-your-real-api-key
